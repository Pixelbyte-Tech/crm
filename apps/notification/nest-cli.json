{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "mail/templates/**/*",
        "outDir": "dist",
        "watchAssets": true
      },
      {
        "include": "mail/i18n/**/*",
        "outDir": "dist",
        "watchAssets": true
      }
    ],
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {
          "classValidatorShim": true,
          "introspectComments": true,
          "dtoFileNameSuffix": [".dto.ts", ".model.ts"]
        }
      }
    ],
    "watchAssets": true
  }
}
